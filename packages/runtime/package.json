{
  "name": "@fro-bot/runtime",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "scripts": {
    "build": "bunx tsc -p tsconfig.json --noEmit && bunx tsdown src/index.ts --format esm --dts --out-dir dist",
    "check-types": "bunx tsc -p tsconfig.json --noEmit",
    "fix": "bunx eslint --fix src",
    "lint": "bunx eslint src",
    "test": "bunx vitest run --passWithNoTests src"
  },
  "dependencies": {
    "@bfra.me/es": "0.1.0",
    "@opencode-ai/sdk": "1.17.9"
  }
}
