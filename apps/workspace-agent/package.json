{
  "name": "@fro-bot/workspace-agent",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "main": "dist/main.mjs",
  "scripts": {
    "build": "bunx tsc -p tsconfig.json --noEmit && bunx tsdown",
    "check-types": "bunx tsc -p tsconfig.json --noEmit",
    "dev": "node --watch dist/main.mjs",
    "fix": "bunx eslint --fix src",
    "lint": "bunx eslint src",
    "test": "bunx vitest run --passWithNoTests src"
  },
  "dependencies": {
    "@hono/node-server": "2.0.10",
    "hono": "4.12.30"
  },
  "devDependencies": {
    "vitest": "4.1.10"
  }
}
